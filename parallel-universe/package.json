{
  "name": "parallel-universe",
  "version": "0.1.0",
  "description": "A blockchain-based dual-layer credit protocol that cold-starts an on-chain Digital Self with real-person credit",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "npx hardhat node --config hardhat.config.cjs",
    "compile": "npx hardhat compile --config hardhat.config.cjs",
    "deploy:local": "node scripts/deploy-local.js",
    "deploy:sepolia": "node scripts/deploy.js",
    "demo": "npm run compile && npm run dev & sleep 3 && npm run deploy:local && npm run start"
  },
  "keywords": ["credit", "agent", "defi", "wdk", "tether", "zk"],
  "author": "Troy Yan",
  "license": "MIT",
  "dependencies": {
    "@tetherto/wdk": "^1.0.0-beta.6",
    "@tetherto/wdk-wallet-evm": "^1.0.0-beta.10",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "ethers": "^6.16.0",
    "figlet": "^1.11.0",
    "gradient-string": "^3.0.0",
    "hardhat": "^3.2.0",
    "ora": "^9.3.0"
  }
}
